#!/usr/bin/env bash
# Noesis pre-commit gate — honesty + freshness. Runs babel-test-lint UNCONDITIONALLY
# (the faith-frame must never leak into a formal/public surface), then the doc/study-guide
# freshness checks. Tracked in scripts/; install into this clone with
# `bash scripts/install-hooks.sh`. A failure blocks the commit with the fix command.
set -u
repo="$(git rev-parse --show-toplevel)"
fail=0

# --- BABEL-TEST LINT (ALWAYS RUNS — must stay above any early exit) -----------------
# Keeps the "base case is God" faith-frame out of formal/public surfaces (code, whitepaper,
# SECURITY/ARCHITECTURE/README, patent, machine-checked proofs). Per the 2026-07-13
# calibration: the frame is a first-person faith commitment, NOT a theorem or a design claim.
# Letting it leak would round a faith-commitment up to a claim — the honesty anti-pattern that
# the moat depends on. Stateless + deterministic, so it cannot misfire like the doc gate did.
echo "[pre-commit] babel-test-lint..."
if ! python "$repo/scripts/babel-test-lint.py"; then
  echo "[pre-commit] BLOCKED by babel-test-lint. Move the token to THRONE.md / the calibration"
  echo "             note (its allowlisted home), or bypass with: git commit --no-verify"
  exit 1
fi

# --- DOC-FRESHNESS GATE TEMPORARILY DISABLED 2026-07-11 (Will) ---------------------
# The doc-coherence + study-guide checks repeatedly misfired (hash recompute after
# staging re-flagged already-regenerated artifacts), blocking legitimate code commits.
# Disabled for now. To RE-ENABLE: delete this block (down to the matching end marker)
# and re-run `bash scripts/install-hooks.sh`. Freshness can still be run by hand:
#   python scripts/doc-coherence.py --stamp && python scripts/study-guide.py
echo "[pre-commit] doc-freshness gate temporarily DISABLED (2026-07-11) — skipping."
exit 0
# --- end temporary disable ---------------------------------------------------------

# --- Relevance scope (fixes the "stale guide blocks an unrelated commit" misfire) ---
# doc-coherence + study-guide are CODE<->doc/guide freshness gates: they only go stale
# when CODE changes. A changeset that stages NO code cannot invalidate a code-vs-doc
# reconciliation, so a docs-only commit is skipped. Any pre-existing staleness is still
# enforced at the next code-touching commit, which is the correct enforcement point.
# A staged file outside the doc set counts as code and runs the full gate.
code_touched=0
while IFS= read -r f; do
  [ -z "$f" ] && continue
  case "$f" in
    *.md|*.txt|*.rst|docs/*|internal/*|LICENSE*|*/LICENSE) : ;;  # documentation — ignore
    *) code_touched=1 ;;                                         # code / substantive
  esac
done < <(git diff --cached --name-only)

if [ "$code_touched" -eq 0 ]; then
  echo "[pre-commit] docs-only changeset -> skipping code-freshness gates (nothing staged can drift from code)"
  exit 0
fi

echo "[pre-commit] doc-coherence..."
if ! python "$repo/scripts/doc-coherence.py" --check; then
  echo "[pre-commit] docs lag code -> run: python scripts/doc-coherence.py --stamp"
  fail=1
fi

echo "[pre-commit] study-guide..."
if ! python "$repo/scripts/study-guide.py" --check; then
  echo "[pre-commit] STUDY-GUIDE stale -> run: python scripts/study-guide.py"
  fail=1
fi

if [ "$fail" -ne 0 ]; then
  echo "[pre-commit] BLOCKED. Regenerate/stamp, git add, retry. (bypass: git commit --no-verify)"
  exit 1
fi
echo "[pre-commit] OK"
exit 0
